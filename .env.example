# ============================================
# 天眼 Tianyan 环境变量配置
# ============================================

# === LLM 配置 ===
# 选择提供商: deepseek / mimo / openai / mock
TIANYAN_LLM_PROVIDER=deepseek

# DeepSeek API Key (推荐，国产大模型，性价比高)
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key

# MIMO API Key (小米大模型)
# MIMO_API_KEY=your-mimo-key

# OpenAI API Key
# OPENAI_API_KEY=sk-your-openai-key

# 自定义API地址 (可选，用于代理或私有部署)
# TIANYAN_LLM_BASE_URL=https://api.deepseek.com/v1

# 模型选择
# TIANYAN_LLM_MODEL=deepseek-chat

# 生成参数
TIANYAN_LLM_MAX_TOKENS=1024
TIANYAN_LLM_TEMPERATURE=0.7
TIANYAN_LLM_TIMEOUT=30.0

# === 服务器配置 ===
TIANYAN_HOST=0.0.0.0
TIANYAN_PORT=8000
DEBUG=True

# === 日志 ===
LOG_LEVEL=INFO
